
# Подключение к базе данных
DB_HOST=postgres
DB_PORT=5432
DB_USER=student
DB_PASSWORD=student_secure_password
DB_NAME=paving_tiles_db

# Настройки приложения
PORT=4200

# JWT настройки
JWT_ACCESS_SECRET=your_super_secret_access_key_change_in_production
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=168h  # 7 дней

# Yandex OAuth
YANDEX_CLIENT_ID=your_yandex_client_id
YANDEX_CLIENT_SECRET=your_yandex_client_secret
YANDEX_REDIRECT_URL=http://localhost:4200/auth/oauth/yandex/callback

APP_ENV=development

